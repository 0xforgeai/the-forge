    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^6.19.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
