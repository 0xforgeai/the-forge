# Database — Railway managed Postgres
DATABASE_URL="postgresql://user:password@host:5432/the_forge?schema=public"

# Server
PORT=3000
NODE_ENV=production

# HMAC secret for answer hashing — generate a strong random string
HMAC_SECRET=""

# Admin panel basic auth
ADMIN_USER=admin
ADMIN_PASS=""

# Sentry DSN (optional)
SENTRY_DSN=

# Game config
INITIAL_BALANCE=1000
INITIAL_GAS=500

# Base Sepolia (contract deployment)
BASE_SEPOLIA_RPC_URL=
PRIVATE_KEY=

# Contract addresses (set after deployment)
FORGE_TOKEN_ADDRESS=
ARENA_VAULT_ADDRESS=
